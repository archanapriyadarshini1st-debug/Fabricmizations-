    const mustHaveList = document.getElementById('must-have-list');
    mustHaveMods.forEach((mod, index) => {
        const item = document.createElement('div');
        item.className = 'mod-item';
        item.style.transitionDelay = `${index * 50}ms`;
        item.innerHTML = `<div class="mod-item-info"><div class="mod-item-name">${mod.name}</div><div class="mod-item-desc">${mod.desc}</div></div><a href="${mod.link}" target="_blank" class="download-btn-small" onclick="event.stopPropagation(); window.open('${mod.link}', '_blank'); return false;">Download</a>`;
        mustHaveList.appendChild(item);
    });
    const optionalList = document.getElementById('optional-list');
    optionalMods.forEach((mod, index) => {
        const item = document.createElement('div');
        item.className = 'mod-item';
        item.style.transitionDelay = `${index * 50}ms`;
        item.innerHTML = `<div class="mod-item-info"><div class="mod-item-name">${mod.name}</div><div class="mod-item-desc">${mod.desc}</div></div><a href="${mod.link}" target="_blank" class="download-btn-small" onclick="event.stopPropagation(); window.open('${mod.link}', '_blank'); return false;">Download</a>`;
        optionalList.appendChild(item);
    });    const detailsGrid = document.getElementById('details-grid');
    const allMods = [...mustHaveMods, ...optionalMods];
    allMods.forEach((mod, index) => {
        const card = document.createElement('div');
        card.className = `detail-card ${mod.type}`;
        card.style.transitionDelay = `${index * 30}ms`;
        let impactClass = 'impact-low', impactLabel = 'Low Impact', impactWidth = '30%';
        if (mod.impact === 'high') { impactClass = 'impact-high'; impactLabel = 'High Impact'; impactWidth = '90%'; }
        else if (mod.impact === 'med') { impactClass = 'impact-med'; impactLabel = 'Medium Impact'; impactWidth = '60%'; }
        card.innerHTML = `<div class="detail-header"><div class="detail-name">${mod.name}</div><span class="detail-type type-${mod.type}">${mod.type}</span></div><p class="detail-desc">${mod.detail}</p><div class="detail-impact"><span>Performance:</span><div class="impact-bar"><div class="impact-fill ${impactClass}" style="width: ${impactWidth}"></div></div><span>${impactLabel}</span></div>`;
        detailsGrid.appendChild(card);
    });
    const initThreeJS = () => {
        const container = document.getElementById('canvas-container');
        const scene = new THREE.Scene();
        scene.fog = new THREE.FogExp2(0xf8f9fa, 0.002);
        const camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.z = 30;
        const renderer = new THREE.WebGLRenderer({ alpha: true, antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(window.devicePixelRatio);
        container.appendChild(renderer.domElement);
        const geometry = new THREE.BoxGeometry(2, 2, 2);
        const materials = [
            new THREE.MeshBasicMaterial({ color: 0x3b82f6, wireframe: true, transparent: true, opacity: 0.15 }),
            new THREE.MeshBasicMaterial({ color: 0x10b981, wireframe: true, transparent: true, opacity: 0.15 }),
            new THREE.MeshBasicMaterial({ color: 0xf59e0b, wireframe: true, transparent: true, opacity: 0.15 }),
        ];
        const cubes = [];
        const cubeCount = 60;
        for (let i = 0; i < cubeCount; i++) {
            const material = materials[Math.floor(Math.random() * materials.length)];
            const cube = new THREE.Mesh(geometry, material);
            cube.position.x = (Math.random() - 0.5) * 100;
            cube.position.y = (Math.random() - 0.5) * 100;
            cube.position.z = (Math.random() - 0.5) * 50 - 10;
            cube.rotation.x = Math.random() * Math.PI;
            cube.rotation.y = Math.random() * Math.PI;
            const scale = Math.random() * 1.5 + 0.5;
            cube.scale.set(scale, scale, scale);
            cube.userData = { rotSpeedX: (Math.random() - 0.5) * 0.02, rotSpeedY: (Math.random() - 0.5) * 0.02, floatSpeed: (Math.random() * 0.02) + 0.005, floatOffset: Math.random() * Math.PI * 2 };
            scene.add(cube);
            cubes.push(cube);
        }
        let mouseX = 0, mouseY = 0;
        const windowHalfX = window.innerWidth / 2, windowHalfY = window.innerHeight / 2;
        document.addEventListener('mousemove', (event) => {
            mouseX = (event.clientX - windowHalfX) * 0.001;
            mouseY = (event.clientY - windowHalfY) * 0.001;
        });        const animate = () => {
            requestAnimationFrame(animate);
            camera.rotation.y += 0.05 * (mouseX - camera.rotation.y);
            camera.rotation.x += 0.05 * (mouseY - camera.rotation.x);
            const time = Date.now() * 0.001;
            cubes.forEach(cube => {
                cube.rotation.x += cube.userData.rotSpeedX;
                cube.rotation.y += cube.userData.rotSpeedY;
                cube.position.y += Math.sin(time + cube.userData.floatOffset) * 0.05;
            });
            renderer.render(scene, camera);
        };
        animate();
        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });
    };
    const initGSAP = () => {
        gsap.registerPlugin(ScrollTrigger);
        gsap.to(".banner-image", { scrollTrigger: { trigger: ".channel-banner", start: "top top", scrub: 1 }, scale: 1, opacity: 1, duration: 1.5, ease: "power2.out" });
        gsap.to(".banner-overlay", { scrollTrigger: { trigger: ".channel-banner", start: "top 70%", toggleActions: "play none none reverse" }, opacity: 1, y: 0, duration: 0.8, delay: 0.3, ease: "power2.out" });
        const tl = gsap.timeline();
        tl.to(".version-badge", { opacity: 1, y: 0, duration: 0.8, ease: "power3.out" })
          .to("h1", { opacity: 1, y: 0, duration: 0.8, ease: "power3.out" }, "-=0.6")
          .to(".hero-sub", { opacity: 1, y: 0, duration: 0.8, ease: "power3.out" }, "-=0.6");
        gsap.to('#must-have-container', { scrollTrigger: { trigger: '#must-have-container', start: "top 80%", toggleActions: "play none none reverse" }, opacity: 1, y: 0, duration: 0.8, ease: "power2.out" });
        gsap.utils.toArray('#must-have-list .mod-item').forEach((item) => {
            gsap.to(item, { scrollTrigger: { trigger: item, start: "top 90%", toggleActions: "play none none reverse" }, opacity: 1, y: 0, duration: 0.5, ease: "power2.out" });
        });
        gsap.to('#optional-container', { scrollTrigger: { trigger: '#optional-container', start: "top 80%", toggleActions: "play none none reverse" }, opacity: 1, y: 0, duration: 0.8, ease: "power2.out" });
        gsap.utils.toArray('#optional-list .mod-item').forEach((item) => {
            gsap.to(item, { scrollTrigger: { trigger: item, start: "top 90%", toggleActions: "play none none reverse" }, opacity: 1, y: 0, duration: 0.5, ease: "power2.out" });
        });
        gsap.utils.toArray('.detail-card').forEach((card, i) => {
            gsap.to(card, { scrollTrigger: { trigger: card, start: "top 85%", toggleActions: "play none none reverse" }, opacity: 1, y: 0, duration: 0.6, delay: i * 0.05, ease: "back.out(1.7)" });
        });
        gsap.utils.toArray('.video-card').forEach((card, i) => {
            gsap.to(card, { scrollTrigger: { trigger: card, start: "top 85%", toggleActions: "play none none reverse" }, opacity: 1, y: 0, duration: 0.6, delay: i * 0.2, ease: "back.out(1.7)" });
        });
    };
    window.addEventListener('DOMContentLoaded', () => { initThreeJS(); initGSAP(); });
</script>
